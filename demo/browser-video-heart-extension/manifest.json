{
  "manifest_version": 3,
  "name": "Open-rPPG Browser Video Heart",
  "description": "Detect heart rate from ordinary web videos using the local Open-rPPG service.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "tabCapture", "offscreen", "storage"],
  "host_permissions": ["http://127.0.0.1:8030/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video Heart"
  }
}
