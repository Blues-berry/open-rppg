{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/portfolio/index.html" },
    { "source": "/:path*", "destination": "/portfolio/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
